<?xml version="1.0" encoding="utf-8"?>
<resources>
    <declare-styleable name="BaseTextView">
        <attr name="textFont" format="enum">
            <enum name="roboto" value="0"/>
        </attr>

        <attr name="textWeight" format="enum">
            <enum name="regular" value="0"/>
            <enum name="medium" value="1"/>
            <enum name="bold" value="2"/>
        </attr>
    </declare-styleable>
    <declare-styleable name="BaseEditText" parent="BaseTextView"/>
</resources>