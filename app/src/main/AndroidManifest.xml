<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <application
        android:name=".BaseApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.AppCompat.NoActionBar"
        tools:targetApi="31">
        <activity
            android:name=".feature.weekly.week_goal.WeekGoalFragment"
            android:exported="false" />
        <activity
            android:name=".feature.setting.SettingFragment"
            android:exported="false" />
        <activity
            android:name=".feature.weekly.add_week_schedule.AddWeekScheduleActivity"
            android:exported="false" />
        <activity
            android:name=".feature.daily.add_daily_schedule.AddDayScheduleActivity"
            android:exported="false" />
        <activity
            android:name=".feature.splash.SplashActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".feature.main.MainActivity"
            android:exported="false" />
    </application>

</manifest>